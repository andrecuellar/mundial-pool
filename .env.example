# --- Database (Supabase Postgres connection string) ---
# Get from: Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# --- Supabase Auth + client ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Only used server-side for admin tasks (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Football data provider (auto-resolution of results) ---
# Options: mock | api-football | football-data | thesportsdb
FOOTBALL_API_PROVIDER=mock
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=

# Shared secret para los cron endpoints (resolve / lock-reminder /
# payment-reminder). Vercel inyecta CRON_SECRET automáticamente en sus
# crons; en local seteá cualquier valor random.
CRON_SECRET=change-me
RESOLUTION_CRON_SECRET=change-me

# --- Web Push notifications ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: o https:// del operador del sitio — exigido por el protocolo Web
# Push para abuse reports.
VAPID_SUBJECT=mailto:tu-email@example.com

# --- Superadmins ---
# Lista separada por coma de emails que pueden acceder al panel /admin.
# El email se compara en lowercase. Si la lista está vacía, el panel queda
# inaccesible para todos (404).
SUPER_ADMIN_EMAILS=

# --- Sentry (opcional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
